<manifest xmlns:android="http://schemas.android.com/apk/res/android">
    <application>
        <activity
            android:name="net.rpcsx.ThorDebugLaunchActivity"
            android:exported="true"
            android:theme="@android:style/Theme.Translucent.NoTitleBar">
            <intent-filter>
                <action android:name="net.rpcsx.THOR_DEBUG_BOOT" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
        </activity>

        <receiver
            android:name="net.rpcsx.ThorDebugPadReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="net.rpcsx.THOR_DEBUG_PAD" />
            </intent-filter>
        </receiver>

        <provider
            android:name="net.rpcsx.ThorDevCoreOverrideProvider"
            android:authorities="${applicationId}.thor-dev-core-override"
            android:exported="false"
            android:initOrder="100" />
    </application>
</manifest>
